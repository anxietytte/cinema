* {
    margin: 0;
    padding: 0;
    box-sizing: border-box;
}

body {
    font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
    background: #0B0B10;
    color: #FFFFFF;
    min-height: 100vh;
}

.page {
    min-height: 100vh;
    display: flex;
    flex-direction: column;
}

.container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 48px;
}

/* ===== Шапка ===== */
.header {
    padding: 32px 0;
    border-bottom: 1px solid rgba(255, 255, 255, 0.08);
}

.header-row {
    display: flex;
    align-items: center;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: 24px;
}

.logo {
    font-size: 24px;
    font-weight: 700;
    letter-spacing: -0.3px;
    background: linear-gradient(135deg, #FFFFFF, #A855F7);
    -webkit-background-clip: text;
    background-clip: text;
    color: transparent;
}

/* Навигация */
.nav {
    display: flex;
    gap: 32px;
}

.nav a {
    color: #FFFFFF;
    text-decoration: none;
    font-size: 15px;
    font-weight: 500;
    opacity: 0.75;
    transition: opacity 0.2s;
}

.nav a:hover {
    opacity: 1;
}

/* Поле поиска */
.search input {
    background: rgba(255, 255, 255, 0.06);
    border: 1px solid rgba(255, 255, 255, 0.1);
    border-radius: 100px;
    padding: 10px 20px;
    color: #FFFFFF;
    font-size: 14px;
    width: 200px;
    outline: none;
    transition: all 0.2s;
}

.search input::placeholder {
    color: rgba(255, 255, 255, 0.4);
}

.search input:focus {
    background: rgba(255, 255, 255, 0.1);
    border-color: rgba(255, 255, 255, 0.25);
    
}
.account-icon {
    cursor: pointer;
    color: #e0e0e0;
    transition: 0.2s;
    display: flex;
    align-items: center;
}

.account-icon:hover {
    color: #cd3c3c;
}

/* ===== Основной контент ===== */
.main {
    flex: 1;
    display: flex;
    align-items: center;
    padding: 60px 0;
}

.content {
    max-width: 680px;
}

/* Заголовок SCREAM 7 */
.title {
    font-size: 72px;
    font-weight: 800;
    letter-spacing: -2px;
    margin-bottom: 24px;
    line-height: 1.1;
}

/* Описание фильма */
.description {
    font-size: 16px;
    line-height: 1.6;
    color: rgba(255, 255, 255, 0.8);
    margin-bottom: 32px;
}

/* Кнопка WATCH NOW */
.watch-btn {
    display: inline-block;
    background: #E50914;
    color: #FFFFFF;
    font-size: 16px;
    font-weight: 700;
    padding: 12px 32px;
    border-radius: 40px;
    text-decoration: none;
    letter-spacing: 0.5px;
    transition: background 0.2s, transform 0.1s;
}

.watch-btn:hover {
    background: #B80C12;
}

.watch-btn:active {
    transform: scale(0.98);
}

/* Дата выхода */
.date {
    margin-top: 24px;
    font-size: 14px;
    color: rgba(255, 255, 255, 0.6);
    border-left: 3px solid #E50914;
    padding-left: 14px;
}
/* Модальное окно */
.modal {
    display: none;
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background: rgba(0,0,0,0.8);
    backdrop-filter: blur(8px);
    z-index: 1000;
    justify-content: center;
    align-items: center;
}

.modal-content {
    background: #111;
    border-radius: 24px;
    padding: 2rem;
    max-width: 400px;
    width: 90%;
    border: 1px solid #cd3c3c;
    position: relative;
}

.close-modal {
    position: absolute;
    top: 15px;
    right: 20px;
    font-size: 28px;
    cursor: pointer;
    color: #aaa;
}

.close-modal:hover {
    color: #cd3c3c;
}

.tabs {
    display: flex;
    gap: 1rem;
    margin-bottom: 1.5rem;
    border-bottom: 1px solid #333;
}

.tab-btn {
    background: none;
    border: none;
    color: #aaa;
    font-size: 1.1rem;
    font-weight: 600;
    padding: 0.5rem 1rem;
    cursor: pointer;
    transition: 0.2s;
}

.tab-btn.active {
    color: #cd3c3c;
    border-bottom: 2px solid #cd3c3c;
}

.form {
    display: none;
}

.form.active-form {
    display: block;
}

.form-group {
    margin-bottom: 1rem;
}

.form-group label {
    display: block;
    margin-bottom: 0.3rem;
    color: #ccc;
    font-size: 0.85rem;
}

.form-group input {
    width: 100%;
    padding: 0.7rem;
    background: #1a1a1a;
    border: 1px solid #333;
    border-radius: 8px;
    color: white;
    font-family: inherit;
}

.form-group input:focus {
    outline: none;
    border-color: #cd3c3c;
}

.submit-btn {
    width: 100%;
    padding: 0.7rem;
    background: #cd3c3c;
    border: none;
    border-radius: 40px;
    color: white;
    font-weight: 600;
    cursor: pointer;
    margin-top: 0.5rem;
}

.submit-btn:hover {
    background: #a52a2a;
}

.user-avatar {
    position: relative;
}

.user-dropdown {
    display: none;
    position: absolute;
    top: 45px;
    right: 0;
    background: #1a1a1a;
    border-radius: 12px;
    padding: 0.5rem 0;
    min-width: 150px;
    border: 1px solid #333;
    z-index: 100;
}

.user-dropdown a {
    display: block;
    padding: 0.5rem 1rem;
    color: #ccc;
    text-decoration: none;
    font-size: 0.85rem;
}

.user-dropdown a:hover {
    background: #2a2a2a;
    color: #cd3c3c;
}

.user-name {
    color: white;
    font-size: 0.85rem;
    margin-right: 0.5rem;
}
/* ===== Адаптив ===== */

@media (max-width: 900px) {
    .container {
        padding: 0 24px;
    }
    
    .header-row {
        flex-direction: column;
        align-items: flex-start;
    }
    
    .title {
        font-size: 52px;
    }
    
    .nav {
        flex-wrap: wrap;
        gap: 24px;
    }
    
    .search input {
        width: 100%;
    }
}

@media (max-width: 500px) {
    .title {
        font-size: 40px;
    }
    
    .description {
        font-size: 14px;
    }
}
